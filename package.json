{
  "name": "exponential",
  "version": "0.1.0",
  "description": "Autonomous agent orchestrator that turns Plane issues into shipped code.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "node --env-file-if-exists=.env --watch --enable-source-maps --import tsx src/index.ts",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@makeplane/plane-node-sdk": "^0.2.11",
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.1.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty"
    ]
  }
}
