# Plane self-hosted API
PLANE_BASE_URL=https://plane.example.com
PLANE_API_KEY=plane_api_xxx
PLANE_WORKSPACE_SLUG=my-workspace
PLANE_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Status name the orchestrator polls for. Defaults to "In Progress".
PLANE_IN_PROGRESS_STATUS=In Progress

# --- Phase 2: Planning agent ---

# Absolute path to a local clone of the summario repo. The orchestrator runs
# git operations directly against this clone and creates a worktree per issue.
# Locally we symlink to an existing dev clone so .env / node_modules / etc.
# stay available; in production this will be a Docker volume.
SUMMARIO_REPO_PATH=/Users/you/code/summario

# Where per-issue worktrees live. Each issue gets <base>/PLANE-<sequence>/.
WORKTREE_BASE_PATH=./workspaces

# Default branch + remote the orchestrator branches/pushes from.
SUMMARIO_DEFAULT_BRANCH=main
SUMMARIO_REMOTE_NAME=origin

# Path to the Claude Code CLI. Default looks up `claude` on PATH.
CLAUDE_BINARY=claude

# Hard timeout per Claude Code session (ms). Default 30 minutes.
CLAUDE_TIMEOUT_MS=1800000

# Extra args passed to every Claude Code invocation (space-separated).
# e.g. "--model opus --add-dir /some/path"
CLAUDE_EXTRA_ARGS=

# --- Phase 3: Building agent ---

# Dev server policy: "auto" (try to start, continue if it fails), "off" (skip
# entirely), or "required" (fail the build if the dev server can't come up).
# Default "auto".
BUILDER_DEV_SERVER=auto

# First port the dev server probes from. The orchestrator scans upward until
# it finds one free. Default 3001.
BUILDER_DEV_SERVER_PORT=3001

# Max orchestrator-level retries when the building agent reports build-failed.
# Default 3.
BUILDER_MAX_ATTEMPTS=3

# --- Phase 4: E2E agent + full pipeline ---

# Plane state names. Defaults match the PRD's status table. If your Plane
# project doesn't have a literal "Failed" state, create one or override.
PLANE_HUMAN_REVIEW_STATUS=Human Review
PLANE_FAILED_STATUS=Failed

# Optional: GitHub repo for summario in "owner/name" form. If unset, the
# orchestrator derives it from `git remote get-url origin` in SUMMARIO_REPO_PATH.
# Required for Vercel preview detection.
# SUMMARIO_GITHUB_REPO=luisKisters/summario

# Vercel deployment protection bypass header value (project settings → Security
# → Deployment Protection → bypass). Passed to the E2E agent so it can fetch
# the preview URL without hitting the Vercel auth wall.
VERCEL_PROTECTION_BYPASS=

# How long to wait for the Vercel preview deployment to reach a terminal state
# before giving up. Default 10 minutes.
VERCEL_READY_TIMEOUT_MS=600000

# Hard timeout per E2E Claude session. Default 20 minutes.
E2E_TIMEOUT_MS=1200000

# Mock test user credentials. The E2E agent uses these to sign in when a
# change requires an authenticated session. Per the summario "agent readiness"
# PRD — create a low-blast-radius dedicated test account.
MOCK_TEST_USER_EMAIL=
MOCK_TEST_USER_PASSWORD=

# Max number of full plan→build→e2e loops before giving up and moving to
# Failed. Default 3 (per PRD).
MAX_PIPELINE_LOOPS=3

# If true, remove the per-issue worktree after a terminal outcome (success or
# failure). Keep false during development so you can inspect the working tree
# afterwards. Default false.
CLEAN_WORKTREE_ON_FINISH=false

# --- Phase 4.5: comment-driven revise loop ---

# How often (ms) the orchestrator polls Plane comments for reviewer feedback.
# Lower = faster interrupts, higher Plane API load. Default 10s.
COMMENT_POLL_INTERVAL_MS=10000

# --- Phase 5 (slice 5a-v2): vercel-build-failure fixup loop ---

# On a failed Vercel preview build, the orchestrator captures the build log
# (`npx vercel inspect --logs`) and spawns a Claude fixup session that
# diagnoses the root cause from the log and commits a fix; the orchestrator
# pushes, Vercel redeploys, repeat. This caps how many fixup attempts run
# before the issue terminal-fails. Default 3.
MAX_PREVIEW_FIXUP_ATTEMPTS=3

# Optional Vercel token. The build-log fetch uses `npx vercel inspect --logs`,
# which works with local keyring auth on a workstation. In Docker / Coolify
# (Phase 8) you'll need to set this and the CLI will pass it through.
# VERCEL_TOKEN=

# --- Runtime ---

# Poll cadence (ms). Default 30000.
POLL_INTERVAL_MS=30000

# SQLite database file path. Default ./data/exponential.sqlite.
DATABASE_PATH=./data/exponential.sqlite

# Log level: trace | debug | info | warn | error. Default info.
LOG_LEVEL=info
