# Plane self-hosted API
PLANE_BASE_URL=https://plane.example.com
PLANE_API_KEY=plane_api_xxx
PLANE_WORKSPACE_SLUG=my-workspace
PLANE_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Status name the orchestrator polls for. Defaults to "In Progress".
PLANE_IN_PROGRESS_STATUS=In Progress

# --- Phase 2: Planning agent ---

# Absolute path to a local clone of the summario repo. The orchestrator runs
# git operations directly against this clone and creates a worktree per issue.
# Locally we symlink to an existing dev clone so .env / node_modules / etc.
# stay available; in production this will be a Docker volume.
SUMMARIO_REPO_PATH=/Users/you/code/summario

# Where per-issue worktrees live. Each issue gets <base>/PLANE-<sequence>/.
WORKTREE_BASE_PATH=./workspaces

# Default branch + remote the orchestrator branches/pushes from.
SUMMARIO_DEFAULT_BRANCH=main
SUMMARIO_REMOTE_NAME=origin

# Path to the Claude Code CLI. Default looks up `claude` on PATH.
CLAUDE_BINARY=claude

# Hard timeout per Claude Code session (ms). Default 30 minutes.
CLAUDE_TIMEOUT_MS=1800000

# Extra args passed to every Claude Code invocation (space-separated).
# e.g. "--model opus --add-dir /some/path"
CLAUDE_EXTRA_ARGS=

# --- Runtime ---

# Poll cadence (ms). Default 30000.
POLL_INTERVAL_MS=30000

# SQLite database file path. Default ./data/exponential.sqlite.
DATABASE_PATH=./data/exponential.sqlite

# Log level: trace | debug | info | warn | error. Default info.
LOG_LEVEL=info
